# The dev shell lives in .nix/ (dot-prefixed); `use flake` reads the root
# flake.nix, which imports .nix/devshell.nix. direnv watches flake.nix and
# flake.lock automatically, but not files the flake imports — so watch the
# devshell explicitly or edits to it will not trigger a reload.
watch_file .nix/devshell.nix
use flake
dotenv_if_exists
